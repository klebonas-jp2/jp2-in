---
import BaseLayout from '~/layouts/BaseLayout.astro';

const journeySteps = [
  {
    number: '1',
    title: 'Alfa+ Dalyviai',
    rhythm: 'Susitikimas',
    text: 'Alfa+ kurso patirtys ir susitikimas su Gyvuoju Dievu.',
    color: '#0CA25A',
  },
  {
    number: '2',
    title: 'Bendrakeleiviai',
    rhythm: 'Apsisprendimas',
    text: 'JP2 Vizijos pažinimas ir apsisprendimas keliauti kartu.',
    color: '#FF3131',
  },
  {
    number: '3',
    title: 'Jėzaus mokiniai',
    rhythm: 'Augimas',
    text: 'Augimas Jėzaus mokinystėje ir duotas Mokinio pažadas.',
    color: '#2B5BC2',
  },
  {
    number: '4',
    title: 'Palydėtojai',
    rhythm: 'JP2 Misijos priėmimas',
    text: 'Dievo dovanų puoselėjimas ir patikėtos Misijos priėmimas.',
    color: '#FEBD59',
  },
];

const missionKeys = [
  {
    title: 'Tikėjimo raktas',
    text: 'Gyvojo Dievo Meilės patirtis ir tikėjimo jėga maldoje.',
    color: '#FEBD59',
  },
  {
    title: 'Evangelizacijos raktas',
    text: 'Drąsus šios Meilės liudijimas ir Evangelijos skelbimas.',
    color: '#0CA25A',
  },
  {
    title: 'Šventimo raktas',
    text: 'Dėkojimas už Dievo Meilę ir Sakramentų šventimas.',
    color: '#FCD501',
  },
  {
    title: 'Tarnystės raktas',
    text: 'Veikli artimo meilė ir tarnystė mažutėliams.',
    color: '#FF3131',
  },
  {
    title: 'Bendrystės raktas',
    text: 'Dalijimasis Dievo Meilės vaisiais ir bendrystė.',
    color: '#004AAD',
  },
];

const quickLinks = [
  { title: 'Pamaldų tvarka', href: '/aktualu/pamaldu-tvarka' },
  { title: 'Registracijos', href: '/aktualu/registracijos' },
  { title: 'Renginiai', href: '/naujienos' },
  { title: 'Skelbimai', href: '/naujienos' },
  { title: 'Maldos intencijos', href: '/aktualu/sv-misiu-intencijos' },
  { title: 'Kontaktai', href: '/aktualu/kontaktai' },
];

const supportWays = ['Aukojimas', 'Malda', 'Savanorystė'];
---
<BaseLayout title="JP2 | Atverkite duris Kristui" description="JP2 parapija kviečia atverti duris Kristui per Meilės Dvasią, Mokinystę ir Misiją.">
  <header class="header">
    <div class="header__inner container">
      <a href="/" class="logo" aria-label="JP2 pradžia">
        <span class="logo__text">jp2.in</span>
      </a>
      <input id="menu-toggle" class="nav-toggle" type="checkbox" aria-label="Atidaryti meniu" aria-controls="main-menu" />
      <label class="menu-button" for="menu-toggle" aria-label="Atidaryti meniu" aria-controls="main-menu">
        <span class="menu-button__text">Meniu</span>
        <span class="menu-button__icon" aria-hidden="true">
          <span class="menu-button__bar"></span>
          <span class="menu-button__bar"></span>
          <span class="menu-button__bar"></span>
        </span>
      </label>
      <nav class="nav" id="main-menu" aria-label="Pagrindinis meniu">
        <a href="/aktualu">AKTUALU</a>
        <a href="/naujienos">NAUJIENOS</a>
        <a href="/dvasingumas">DVASINGUMAS</a>
        <a href="/bendruomene">BENDRUOMENĖ</a>
        <a href="/mokinyste">MOKINYSTĖ</a>
        <a href="/misiju-centras">MISIJŲ CENTRAS</a>
        <a href="/parama">PARAMA</a>
        <a class="button-secondary header__cta" href="/bendruomene">BENDRUOMENĖS ERDVĖ</a>
      </nav>
    </div>
  </header>

  <main>
    <section class="hero">
      <div class="container hero__inner">
        <div class="hero__content">
          <p class="section-kicker hero__eyebrow">VILNIAUS ŠV. JONO PAULIAUS II PARAPIJA</p>
          <h1 class="hero__title">Atverkite duris Kristui!</h1>
          <p class="hero__description">
            JP2 parapija kviečia Jus patirti Dievo Meilę, rasti bendrystę ir eiti kartu Jėzaus mokinystės bei misijos keliu.
          </p>
          <div class="cta-group hero__actions">
            <a class="button-primary" href="/bendruomene/jp2-vizija">Pažink JP2!</a>
            <a class="button-secondary" href="/mokinyste">Keliauk kartu!</a>
            <a class="button-accent" href="/parama">Paremk JP2 Misiją!</a>
          </div>
        </div>
        <div class="hero__visual" aria-hidden="true">
          <div class="visual-frame visual-frame--hero">
            <div class="visual-frame__surface"></div>
          </div>
        </div>
      </div>
    </section>

    <section class="story-section story-section--vision" id="vizija">
      <div class="container story-layout">
        <div class="story-copy">
          <p class="section-kicker">JP2 kvietimas ir mūsų Vizija</p>
          <h2 class="section-title">Gimėme kaip atsakas į šį kvietimą</h2>
          <p class="text-lead">
            Vilniaus šv. Jono Pauliaus II parapija yra kvietimas atverti duris Kristui, bendruomenei ir misijai.
          </p>
          <a class="button-secondary story-link" href="/bendruomene/jp2-vizija">Susipažinti su JP2 Vizija</a>
        </div>
        <aside class="quote-panel">
          <p class="quote-panel__mark">„</p>
          <h3>Atveriame duris Kristui į žmonių gyvenimus!</h3>
          <p>Meilės Dvasioje per Jo Misiją ir Mokinystę...</p>
        </aside>
      </div>
    </section>

    <section class="story-section story-section--journey" id="mokinyste">
      <div class="container">
        <div class="section-intro">
          <p class="section-kicker">Mokinystės kelionė</p>
          <h2 class="section-title">Mūsų bendruomenės žingsniai JP2 Vizijos link</h2>
          <p class="text-lead">
            Tai mūsų bendruomenės kelias: nuo pirmo susitikimo su Gyvuoju Dievu iki brandžios Jėzaus mokinystės ir Jo Misijos tarnystės.
          </p>
        </div>

        <div class="journey-map" aria-label="Mokinystės kelionės žingsniai">
          {journeySteps.map((step) => (
            <div class="journey-marker" style={`--step-color: ${step.color}`}>
              <span class="journey-marker__dot" aria-hidden="true"></span>
              <span>{step.title}</span>
            </div>
          ))}
        </div>

        <div class="journey-cards">
          {journeySteps.map((step) => (
            <article class="journey-card" style={`--step-color: ${step.color}`}>
              <span class="journey-card__number">{step.number}</span>
              <p class="journey-card__rhythm">{step.rhythm}</p>
              <h3>{step.title}</h3>
              <p>{step.text}</p>
            </article>
          ))}
        </div>

        <div class="cta-group section-actions">
          <a class="button-primary" href="/mokinyste">Atrask Mokinystės kelionę</a>
          <a class="button-secondary" href="/mokinyste/kas-yra-mokinystes-kelione">Sužinok daugiau</a>
        </div>
      </div>
    </section>

    <section class="story-section" id="misijos-raktai">
      <div class="container story-layout story-layout--mission">
        <div class="story-copy">
          <p class="section-kicker">Misijos raktai</p>
          <h2 class="section-title">Raktai, kuriais atveriame duris Kristui</h2>
          <p class="text-lead">
            Šiais raktais atveriame duris Kristui į savo ir sutiktų žmonių gyvenimus.
          </p>
          <a class="button-secondary story-link" href="/bendruomene/misijos-raktai">Atrask JP2 Misiją</a>
        </div>
        <div class="visual-frame visual-frame--keys" aria-hidden="true">
          <div class="visual-frame__surface"></div>
        </div>
      </div>

      <div class="container mission-key-grid">
        {missionKeys.map((key) => (
          <article class="mission-key-card" style={`--key-color: ${key.color}`}>
            <span class="mission-key-card__symbol" aria-hidden="true"></span>
            <h3>{key.title}</h3>
            <p>{key.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="story-section story-section--quick" id="aktualu">
      <div class="container quick-layout">
        <div class="quick-copy">
          <p class="section-kicker">Aktualu</p>
          <h2 class="section-title">Tai, kas gali būti svarbu ir Tau</h2>
          <a class="button-secondary story-link" href="/aktualu">Peržiūrėti viską</a>
        </div>
        <div class="quick-links" aria-label="Greitos praktinės nuorodos">
          {quickLinks.map((link) => (
            <a class="quick-link" href={link.href}>
              <span class="quick-link__icon" aria-hidden="true"></span>
              <span>{link.title}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="story-section" id="misiju-centras">
      <div class="container story-layout story-layout--reversed">
        <div class="visual-frame visual-frame--center" aria-hidden="true">
          <div class="visual-frame__surface"></div>
        </div>
        <div class="story-copy">
          <p class="section-kicker">Misijų centras</p>
          <h2 class="section-title">Naujosios Evangelizacijos namai Vilniuje</h2>
          <p class="text-lead">
            JP2 Misijų centras – tai ne tik pastatas, bet namai maldai, mokinystei, misijai ir bendruomenei.
          </p>
          <a class="button-primary story-link" href="/misiju-centras">Sužinok daugiau</a>
        </div>
      </div>
    </section>

    <section class="story-section story-section--community" id="bendruomene">
      <div class="container story-layout">
        <div class="story-copy">
          <p class="section-kicker">Bendruomenė</p>
          <h2 class="section-title">Mūsų bendrystės erdvė</h2>
          <p class="text-lead">
            JP2 yra atvira ir auganti Kristaus mokinių bendruomenė, kurioje žmogus kviečiamas melstis, tarnauti ir keliauti kartu.
          </p>
          <a class="button-secondary story-link" href="/bendruomene">Susipažinti</a>
        </div>
        <div class="visual-frame visual-frame--community" aria-hidden="true">
          <div class="visual-frame__surface"></div>
        </div>
      </div>
    </section>

    <section class="story-section story-section--support" id="parama">
      <div class="container support-layout">
        <div class="story-copy">
          <p class="section-kicker">Parama</p>
          <h2 class="section-title">Tavo parama padeda augti JP2 Misijai</h2>
          <p class="text-lead">
            Dėkojame už kiekvieną maldą, auką ir savanorystę. Kartu kuriame namus, kuriuose atsiveria durys Kristui.
          </p>
          <a class="button-accent story-link" href="/parama">Paremk JP2 Misiją!</a>
        </div>
        <div class="support-actions" aria-label="Paramos būdai">
          {supportWays.map((way) => (
            <div class="support-action">
              <span class="support-action__icon" aria-hidden="true"></span>
              <span>{way}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <footer class="footer">
      <div class="container footer__inner">
        <div>
          <h3>Kontaktai</h3>
          <p>Mūsų parapija kviečia susisiekti ir ateiti dalintis malda bei bendryste.</p>
        </div>
        <div>
          <h3>Adresas</h3>
          <p>Vilnius, Lietuva</p>
        </div>
        <div>
          <h3>Greitos nuorodos</h3>
          <p><a href="/aktualu">Aktualu</a></p>
          <p><a href="/bendruomene/jp2-vizija">JP2 Vizija</a></p>
          <p><a href="/mokinyste">Mokinystė</a></p>
        </div>
      </div>
      <div class="container footer__legal">
        <p>JP2 parapijos svetainės pirma versija. Visi tekstai ir struktūra sukurti remiantis JP2 Vizijos bei dizaino gairėmis.</p>
      </div>
    </footer>
  </main>
</BaseLayout>
