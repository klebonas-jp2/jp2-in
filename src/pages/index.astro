---
import BaseLayout from '~/layouts/BaseLayout.astro';
---
<BaseLayout title="JP2 | Atverkite duris Kristui" description="JP2 parapija kviečia atverti duris Kristui per Meilės Dvasią, Mokinystę ir Misiją.">
  <header class="header">
    <div class="header__inner container">
      <a href="/" class="logo" aria-label="JP2 pradžia">
        <span class="logo__text">jp2.in</span>
      </a>
      <input id="menu-toggle" class="nav-toggle" type="checkbox" aria-label="Atidaryti meniu" aria-controls="main-menu" />
      <label class="menu-button" for="menu-toggle" aria-label="Atidaryti meniu" aria-controls="main-menu">
        <span class="menu-button__text">Meniu</span>
        <span class="menu-button__icon" aria-hidden="true">
          <span class="menu-button__bar"></span>
          <span class="menu-button__bar"></span>
          <span class="menu-button__bar"></span>
        </span>
      </label>
      <nav class="nav" id="main-menu" aria-label="Pagrindinis meniu">
        <a href="/aktualu">AKTUALU</a>
        <a href="/naujienos">NAUJIENOS</a>
        <a href="/dvasingumas">DVASINGUMAS</a>
        <a href="/bendruomene">BENDRUOMENĖ</a>
        <a href="/mokinyste">MOKINYSTĖ</a>
        <a href="/misiju-centras">MISIJŲ CENTRAS</a>
        <a href="/parama">PARAMA</a>
        <a class="button-secondary header__cta" href="/bendruomene">BENDRUOMENĖS ERDVĖ</a>
      </nav>
    </div>
  </header>

  <main>
    <section class="hero">
      <div class="container hero__inner">
        <div class="hero__content">
          <p class="hero__eyebrow">Atverkite duris Kristui</p>
          <h1 class="hero__title">Atverkite duris Kristui!</h1>
          <p class="hero__description">
            JP2 parapija kviečia Jus patirti Dievo Meilę, rasti bendrystę ir eiti kartu Jėzaus mokinystės bei misijos keliu.
          </p>
          <div class="cta-group hero__actions">
            <a class="button-primary" href="/bendruomene/jp2-vizija">Pažink JP2!</a>
            <a class="button-secondary" href="/mokinyste">Keliauk kartu!</a>
            <a class="button-accent" href="/parama">Paremk JP2 Misiją!</a>
          </div>
        </div>
        <div class="hero__visual" aria-hidden="true">
          <svg viewBox="0 0 640 520" fill="none" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="hero-panel" x1="320" y1="36" x2="320" y2="484" gradientUnits="userSpaceOnUse">
                <stop stop-color="#FFFFFF" />
                <stop offset="1" stop-color="#F4F9FD" />
              </linearGradient>
              <linearGradient id="hero-light" x1="320" y1="128" x2="320" y2="392" gradientUnits="userSpaceOnUse">
                <stop stop-color="#FEF3CC" stop-opacity="0.95" />
                <stop offset="1" stop-color="#FEF3CC" stop-opacity="0" />
              </linearGradient>
              <linearGradient id="hero-path" x1="320" y1="240" x2="320" y2="470" gradientUnits="userSpaceOnUse">
                <stop stop-color="#DCEFFA" />
                <stop offset="1" stop-color="#FFFFFF" />
              </linearGradient>
            </defs>

            <rect x="16" y="20" width="608" height="480" rx="42" fill="url(#hero-panel)" />
            <circle cx="476" cy="118" r="74" fill="#157DBF" fill-opacity="0.08" />
            <circle cx="186" cy="140" r="58" fill="#FEBD59" fill-opacity="0.16" />
            <circle cx="512" cy="360" r="66" fill="#FEBD59" fill-opacity="0.08" />

            <path d="M214 462C230 406 262 342 320 262C378 342 410 406 426 462H214Z" fill="url(#hero-path)" />
            <path d="M238 438C260 388 288 339 320 295C352 339 380 388 402 438" stroke="#D1E7F5" stroke-width="10" stroke-linecap="round" />

            <path d="M246 402V202C246 135 278 92 320 92C362 92 394 135 394 202V402H246Z" fill="#EAF4FB" />
            <path d="M320 128L434 404H206L320 128Z" fill="url(#hero-light)" />
            <path d="M266 388V226C266 173 288 140 318 140V356L266 388Z" fill="#157DBF" fill-opacity="0.9" />
            <path d="M374 388V226C374 173 352 140 322 140V356L374 388Z" fill="#7CC2EA" fill-opacity="0.96" />
            <path d="M320 166C335 166 348 178 348 193C348 204 342 214 333 220L320 252L307 220C298 214 292 204 292 193C292 178 305 166 320 166Z" fill="#FEBD59" />

            <path d="M508 214V146" stroke="#157DBF" stroke-width="8" stroke-linecap="round" />
            <path d="M484 170H532" stroke="#157DBF" stroke-width="8" stroke-linecap="round" />
            <path d="M454 246C474 234 492 228 508 228C524 228 542 234 562 246" stroke="#A9D4EE" stroke-width="8" stroke-linecap="round" />

            <ellipse cx="278" cy="398" rx="10" ry="16" transform="rotate(-20 278 398)" fill="#0CA25A" />
            <ellipse cx="302" cy="424" rx="10" ry="16" transform="rotate(-18 302 424)" fill="#FF3131" />
            <ellipse cx="334" cy="430" rx="10" ry="16" transform="rotate(16 334 430)" fill="#157DBF" />
            <ellipse cx="360" cy="404" rx="10" ry="16" transform="rotate(18 360 404)" fill="#FEBD59" />
          </svg>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h2 class="section-title">Atveriame duris Kristui į žmonių gyvenimus</h2>
        <p class="text-lead">
          Meilės Dvasioje per Jo Misiją ir Mokinystę… JP2 svetainė yra kvietimas susipažinti su parapijos kelione ir atrasti naują bendrystę su Dievu.
        </p>
      </div>
    </section>

    <section class="section section--light">
      <div class="container">
        <div class="features">
          <article class="card features__item card--highlight">
            <h3>Alfa+ Dalyviai</h3>
            <p>Alfa+ kurso patirtys ir susitikimas su Gyvuoju Dievu.</p>
          </article>
          <article class="card features__item card--highlight">
            <h3>Bendrakeleiviai</h3>
            <p>JP2 Vizijos pažinimas ir apsisprendimas keliauti kartu.</p>
          </article>
          <article class="card features__item card--highlight">
            <h3>Jėzaus mokiniai</h3>
            <p>Augimas Jėzaus mokinystėje ir duotas Mokinio pažadas.</p>
          </article>
          <article class="card features__item card--highlight">
            <h3>Palydėtojai</h3>
            <p>Dievo dovanų puoselėjimas ir patikėtos Misijos priėmimas.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">Misijos raktai</h2>
          <p class="text-lead">Kiekvienas raktas atspindi JP2 parapijos misijos kryptį ir Dievo Meilės veikimą mūsų gyvenimuose.</p>
        </div>
        <div class="feature-grid">
          <article class="card">
            <h3>Tikėjimo raktas</h3>
            <p>Gyvojo Dievo Meilės patirtis ir tikėjimo jėga maldoje.</p>
          </article>
          <article class="card">
            <h3>Evangelizacijos raktas</h3>
            <p>Drąsus šios Meilės liudijimas ir Evangelijos skelbimas.</p>
          </article>
          <article class="card">
            <h3>Šventimo raktas</h3>
            <p>Dėkojimas už Dievo Meilę ir Sakramentų šventimas.</p>
          </article>
          <article class="card">
            <h3>Tarnystės raktas</h3>
            <p>Veikli artimo meilė ir tarnystė mažutėliams.</p>
          </article>
          <article class="card">
            <h3>Bendrystės raktas</h3>
            <p>Dalijimasis Dievo Meilės vaisiais ir bendrystė.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section section--light">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">Aktualu</h2>
          <p class="text-lead">Greitas kelias į svarbiausią parapijos informaciją: pamaldos, registracijos ir praktinė pagalba.</p>
        </div>
        <div class="feature-grid">
          <article class="card">
            <h3>Pamaldų tvarka</h3>
            <p>Sužinok, kada vyksta Šv. Mišios ir maldos susitikimai parapijoje.</p>
          </article>
          <article class="card">
            <h3>Registracijos</h3>
            <p>Rask patvirtintą kelią registruotis į parapijos renginius ar kursus.</p>
          </article>
          <article class="card">
            <h3>Skelbimai</h3>
            <p>Peržiūrėk naujausius parapijos kvietimus ir žinias.</p>
          </article>
          <article class="card">
            <h3>Kunigų patarnavimai</h3>
            <p>Sužinok, kaip kreiptis dėl pastoracinių reikmių ir parapijos pagalbos.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h2 class="section-title">Misijų centras</h2>
        <p class="text-lead">JP2 Misijų centras – tai ne tik pastatas, bet žadinanti vieta maldai, mokinystei ir bendruomenei.</p>
      </div>
    </section>

    <section class="section section--light">
      <div class="container">
        <h2 class="section-title">Bendruomenė</h2>
        <p class="text-lead">Prisijunk prie JP2 bendruomenės: kartu melstis, tarnauti ir augti žingsnis po žingsnio.</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="card card--highlight">
          <h2 class="section-title">Paremk JP2 Misiją</h2>
          <p class="text-lead">Kviečiame prisidėti prie JP2 parapijos misijos: tu esi svarbi bendruomenės dalis.</p>
          <a class="button-primary" href="/parama">Paremk JP2 Misiją!</a>
        </div>
      </div>
    </section>

    <footer class="footer">
      <div class="container footer__inner">
        <div>
          <h3>Kontaktai</h3>
          <p>Mūsų parapija kviečia susisiekti ir ateiti dalintis malda bei bendryste.</p>
        </div>
        <div>
          <h3>Adresas</h3>
          <p>Vilnius, Lietuva</p>
        </div>
        <div>
          <h3>Greitos nuorodos</h3>
          <p><a href="/aktualu">Aktualu</a></p>
          <p><a href="/bendruomene/jp2-vizija">JP2 Vizija</a></p>
          <p><a href="/mokinyste">Mokinystė</a></p>
        </div>
      </div>
      <div class="container footer__legal">
        <p>JP2 parapijos svetainės pirma versija. Visi tekstai ir struktūra sukurti remiantis JP2 Vizijos bei dizaino gairėmis.</p>
      </div>
    </footer>
  </main>
</BaseLayout>
