{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "allowJs": true,
    "checkJs": false,
    "baseUrl": ".",
    "paths": {
      "~/*": ["./src/*"]
    },
    "types": ["node"]
  },
  "imports": {
    "astro/*": ["./node_modules/astro/*"]
  },
  "include": ["src", "astro.config.mjs"]
}
